  "db_name": "PostgreSQL",
  "query": "\n        SELECT id, project_id, deployment_hash, user_id, deleted, status, runtime, metadata,\n               last_seen_at, created_at, updated_at\n        FROM deployment\n        WHERE user_id = $1 AND project_id = $2 AND deleted = false\n        ORDER BY created_at DESC\n        LIMIT $3\n        ",
